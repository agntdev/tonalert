[
  {
    "name": "/start smoke",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🇺🇸 USD","callback_data":"onboard:fiat:USD"}],[{"text":"🇪🇺 EUR","callback_data":"onboard:fiat:EUR"}],[{"text":"🇬🇧 GBP","callback_data":"onboard:fiat:GBP"}],[{"text":"🇯🇵 JPY","callback_data":"onboard:fiat:JPY"}]] } } }
    ]
  },
  {
    "name": "/start fiat selection",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send": { "callback_data": "onboard:fiat:USD" } },
      { "expect": { "reply": "Got it! Your preferred fiat is set to USD." } }
    ]
  }
]