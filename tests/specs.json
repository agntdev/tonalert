[
  {
    "name": "/start smoke",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "expect": { "reply": "Please select your preferred fiat currency" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"USD ($)","callback_data":"fiat_select:USD"},{"text":"EUR (€)","callback_data":"fiat_select:EUR"},{"text":"GBP (£)","callback_data":"fiat_select:GBP"},{"text":"RUB (₽)","callback_data":"fiat_select:RUB"}]] } } }
    ]
  },
  {
    "name": "/help command",
    "steps": [
      { "send": "/help" },
      { "expect": { "reply": "Available commands:" } }
    ]
  },
  {
    "name": "unknown message fallback",
    "steps": [
      { "send": "hello bot" },
      { "expect": { "reply": "Type /help to see available commands." } }
    ]
  },
  {
    "name": "unknown command fallback",
    "steps": [
      { "send": "/foobar" },
      { "expect": { "reply": "Type /help to see available commands." } }
    ]
  },
  {
    "name": "/add without query",
    "steps": [
      { "send": "/add" },
      { "expect": { "reply": "Please provide a token symbol or contract address to search for." } }
    ]
  },
  {
    "name": "/add with valid symbol (TON)",
    "steps": [
      { "send": "/add TON" },
      { "expect": { "reply": "Search results for" } },
      { "expect": { "reply": "TON" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"➕ Add TON","callback_data":"add:TON"}]] } } }
    ]
  },
  {
    "name": "/add with unknown symbol",
    "steps": [
      { "send": "/add XYZUNKNOWN" },
      { "expect": { "reply": "No tokens found matching" } }
    ]
  },
  {
    "name": "fiat selection: USD",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:USD" },
      { "expect": { "reply": "Fiat currency set to USD ($)." } },
      { "expect": { "reply": "please select your timezone" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🕐 Auto-detect (UTC)","callback_data":"tz_select:UTC"}]] } } }
    ]
  },
  {
    "name": "timezone selection: UTC",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:USD" },
      { "expect": { "reply": "Fiat currency set to USD ($)." } },
      { "send_callback": "tz_select:UTC" },
      { "expect": { "reply": "Timezone set to UTC (London)." } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🚀 Set Alert","callback_data":"menu:set_alert"}],[{"text":"📊 My Alerts","callback_data":"menu:my_alerts"}],[{"text":"ℹ️ Help","callback_data":"menu:help"}]] } } }
    ]
  },
  {
    "name": "timezone selection: UTC+8 (Shanghai)",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:EUR" },
      { "expect": { "reply": "Fiat currency set to EUR (€)." } },
      { "send_callback": "tz_select:UTC+8" },
      { "expect": { "reply": "Timezone set to UTC+8 (Shanghai)." } },
      { "expect": { "reply": "Use the menu below to get started." } }
    ]
  },
  {
    "name": "/list empty watchlist",
    "steps": [
      { "send": "/list" },
      { "expect": { "reply": "Your watchlist is empty." } }
    ]
  },
  {
    "name": "/list with a rule in watchlist",
    "steps": [
      { "send": "/add TON" },
      { "expect": { "reply": "Search results for" } },
      { "send_callback": "add:TON" },
      { "expect": { "reply": "Configure alert for" } },
      { "send_callback": "rule:price_below" },
      { "expect": { "reply": "Enter the target price for" } },
      { "send": "2.00" },
      { "expect": { "reply": "Alert rule saved for" } },
      { "send": "/list" },
      { "expect": { "reply": "Your Watchlist" } },
      { "expect": { "reply": "TON" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"💵 Price now","callback_data":"price_now:TON"}],[{"text":"✏️ Edit rule","callback_data":"edit_rule:TON:price_below"}],[{"text":"🗑 Remove","callback_data":"remove:TON:price_below"}]] } } }
    ]
  },
  {
    "name": "remove rule via /list",
    "steps": [
      { "send": "/add TON" },
      { "expect": { "reply": "Search results for" } },
      { "send_callback": "add:TON" },
      { "expect": { "reply": "Configure alert for" } },
      { "send_callback": "rule:price_below" },
      { "expect": { "reply": "Enter the target price for" } },
      { "send": "2.00" },
      { "expect": { "reply": "Alert rule saved for" } },
      { "send": "/list" },
      { "expect": { "reply": "Your Watchlist" } },
      { "send_callback": "remove:TON:price_below" },
      { "send": "/list" },
      { "expect": { "reply": "Your watchlist is empty." } }
    ]
  },
  {
    "name": "edit rule via /list",
    "steps": [
      { "send": "/add TON" },
      { "expect": { "reply": "Search results for" } },
      { "send_callback": "add:TON" },
      { "expect": { "reply": "Configure alert for" } },
      { "send_callback": "rule:price_below" },
      { "expect": { "reply": "Enter the target price for" } },
      { "send": "2.00" },
      { "expect": { "reply": "Alert rule saved for" } },
      { "send": "/list" },
      { "expect": { "reply": "Your Watchlist" } },
      { "send_callback": "edit_rule:TON:price_below" },
      { "expect": { "reply": "Enter the new target price for" } },
      { "send": "3.00" },
      { "expect": { "reply": "Alert rule saved for" } },
      { "send": "/list" },
      { "expect": { "reply": "Your Watchlist" } },
      { "expect": { "reply": "$3.00" } }
    ]
  },
  {
    "name": "/quiet displays settings",
    "steps": [
      { "send": "/quiet" },
      { "expect": { "reply": "Quiet Hours Settings" } },
      { "expect": { "reply": "ON — 23:00 to 07:00" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🔕 Disable quiet hours","callback_data":"quiet:toggle"}],[{"text":"⏰ Start: 23:00","callback_data":"quiet:set_start"}],[{"text":"🌅 End: 07:00","callback_data":"quiet:set_end"}],[{"text":"⚡ Immediate: OFF (tap to enable)","callback_data":"quiet:toggle_immediate"}]] } } }
    ]
  },
  {
    "name": "/quiet toggle disable",
    "steps": [
      { "send": "/quiet" },
      { "expect": { "reply": "Quiet Hours Settings" } },
      { "send_callback": "quiet:toggle" },
      { "expect": { "reply": "OFF" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🔔 Enable quiet hours","callback_data":"quiet:toggle"}],[{"text":"⏰ Start: 23:00","callback_data":"quiet:set_start"}],[{"text":"🌅 End: 07:00","callback_data":"quiet:set_end"}],[{"text":"⚡ Immediate: OFF (tap to enable)","callback_data":"quiet:toggle_immediate"}]] } } }
    ]
  },
  {
    "name": "/stats by non-owner is denied",
    "steps": [
      { "send": "/stats" },
      { "expect": { "reply": "This command is only available to the bot owner." } }
    ]
  },
  {
    "name": "/stats by owner shows analytics",
    "steps": [
      { "send": "/stats", "from": "owner" },
      { "expect": { "reply": "Bot Statistics" } },
      { "expect": { "reply": "Total users:" } },
      { "expect": { "reply": "Active watch rules:" } },
      { "expect": { "reply": "Alerts fired (last 24h):" } }
    ]
  },
  {
    "name": "/morning displays settings",
    "steps": [
      { "send": "/morning" },
      { "expect": { "reply": "Morning Summary Settings" } },
      { "expect": { "reply": "ON — daily at 09:00" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🔕 Disable morning summary","callback_data":"morning:toggle"}],[{"text":"⏰ Time: 09:00","callback_data":"morning:set_time"}]] } } }
    ]
  },
  {
    "name": "/morning toggle disable",
    "steps": [
      { "send": "/morning" },
      { "expect": { "reply": "Morning Summary Settings" } },
      { "send_callback": "morning:toggle" },
      { "expect": { "reply": "OFF" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🔔 Enable morning summary","callback_data":"morning:toggle"}],[{"text":"⏰ Time: 09:00","callback_data":"morning:set_time"}]] } } }
    ]
  },
  {
    "name": "/morning set time",
    "steps": [
      { "send": "/morning" },
      { "expect": { "reply": "Morning Summary Settings" } },
      { "send_callback": "morning:set_time" },
      { "expect": { "reply": "Current morning summary time:" } },
      { "expect": { "reply": "Select a new time or enter a custom one:" } },
      { "send_callback": "morning_set_time:07:00" },
      { "expect": { "reply": "ON — daily at 07:00" } }
    ]
  },
  {
    "name": "morning summary onboarding flow",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:USD" },
      { "expect": { "reply": "Fiat currency set to USD ($)." } },
      { "send_callback": "tz_select:UTC" },
      { "expect": { "reply": "Timezone set to UTC (London)." } },
      { "expect": { "reply": "Would you like to receive a daily morning summary" } },
      { "send_callback": "morning_summary:yes" },
      { "expect": { "reply": "You'll receive a daily morning summary" } },
      { "expect": { "reply": "Select a time or enter a custom one:" } },
      { "send_callback": "morning_time:08:00" },
      { "expect": { "reply": "Morning summary time set to" } },
      { "expect": { "reply": "Use the menu below to get started." } }
    ]
  },
  {
    "name": "/help mentions morning command",
    "steps": [
      { "send": "/help" },
      { "expect": { "reply": "/morning" } }
    ]
  },
  {
    "name": "/export by non-owner is denied",
    "steps": [
      { "send": "/export" },
      { "expect": { "reply": "This command is only available to the bot owner." } }
    ]
  },
  {
    "name": "/export by owner with no events",
    "steps": [
      { "send": "/export", "from": "owner" },
      { "expect": { "reply": "No alert events found" } }
    ]
  },
  {
    "name": "/export by owner with invalid date",
    "steps": [
      { "send": "/export not-a-date", "from": "owner" },
      { "expect": { "reply": "Invalid date format." } }
    ]
  },
  {
    "name": "/help mentions export command",
    "steps": [
      { "send": "/help" },
      { "expect": { "reply": "/export" } }
    ]
  }
]