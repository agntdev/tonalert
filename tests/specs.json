[
  {
    "name": "/start smoke",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "expect": { "reply": "Please select your preferred fiat currency" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"USD ($)","callback_data":"fiat_select:USD"},{"text":"EUR (€)","callback_data":"fiat_select:EUR"},{"text":"GBP (£)","callback_data":"fiat_select:GBP"},{"text":"RUB (₽)","callback_data":"fiat_select:RUB"}]] } } }
    ]
  },
  {
    "name": "/help command",
    "steps": [
      { "send": "/help" },
      { "expect": { "reply": "Available commands:" } }
    ]
  },
  {
    "name": "unknown message fallback",
    "steps": [
      { "send": "hello bot" },
      { "expect": { "reply": "Type /help to see available commands." } }
    ]
  },
  {
    "name": "unknown command fallback",
    "steps": [
      { "send": "/foobar" },
      { "expect": { "reply": "Type /help to see available commands." } }
    ]
  },
  {
    "name": "/add without query",
    "steps": [
      { "send": "/add" },
      { "expect": { "reply": "Please provide a token symbol or contract address to search for." } }
    ]
  },
  {
    "name": "/add with valid symbol (TON)",
    "steps": [
      { "send": "/add TON" },
      { "expect": { "reply": "Search results for" } },
      { "expect": { "reply": "TON" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"➕ Add TON","callback_data":"add:TON"}]] } } }
    ]
  },
  {
    "name": "/add with unknown symbol",
    "steps": [
      { "send": "/add XYZUNKNOWN" },
      { "expect": { "reply": "No tokens found matching" } }
    ]
  },
  {
    "name": "fiat selection: USD",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:USD" },
      { "expect": { "reply": "Fiat currency set to USD ($)." } },
      { "expect": { "reply": "please select your timezone" } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🕐 Auto-detect (UTC)","callback_data":"tz_select:UTC"}]] } } }
    ]
  },
  {
    "name": "timezone selection: UTC",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:USD" },
      { "expect": { "reply": "Fiat currency set to USD ($)." } },
      { "send_callback": "tz_select:UTC" },
      { "expect": { "reply": "Timezone set to UTC (London)." } },
      { "expect": { "reply_markup": { "inline_keyboard": [[{"text":"🚀 Set Alert","callback_data":"menu:set_alert"}],[{"text":"📊 My Alerts","callback_data":"menu:my_alerts"}],[{"text":"ℹ️ Help","callback_data":"menu:help"}]] } } }
    ]
  },
  {
    "name": "timezone selection: UTC+8 (Shanghai)",
    "steps": [
      { "send": "/start" },
      { "expect": { "reply": "Welcome to TonAlert, Test User!" } },
      { "send_callback": "fiat_select:EUR" },
      { "expect": { "reply": "Fiat currency set to EUR (€)." } },
      { "send_callback": "tz_select:UTC+8" },
      { "expect": { "reply": "Timezone set to UTC+8 (Shanghai)." } },
      { "expect": { "reply": "Use the menu below to get started." } }
    ]
  }
]